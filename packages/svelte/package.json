{
	"name": "@dialog-fn/svelte",
	"version": "4.1.1",
	"description": "Promise-based dialogs for Svelte — open a dialog and await the result. Headless, unstyled, zero dependencies, no providers.",
	"keywords": [
		"dialog",
		"modal",
		"svelte",
		"sveltekit",
		"confirm",
		"confirmation",
		"prompt",
		"toast",
		"drawer",
		"promise",
		"async",
		"await",
		"headless",
		"unstyled",
		"imperative",
		"popup"
	],
	"homepage": "https://dialog-fn.github.io/dialog-fn/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dialog-fn/dialog-fn",
		"directory": "packages/svelte"
	},
	"bugs": {
		"url": "https://github.com/dialog-fn/dialog-fn/issues"
	},
	"author": {
		"name": "Jacob Gonzalez",
		"email": "hello@jacobgonzalez.dev"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "pnpm run package",
		"test": "pnpm run test:unit",
		"test:unit": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^4.0.0"
	},
	"dependencies": {
		"@dialog-fn/core": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@testing-library/jest-dom": "^6.4.8",
		"@testing-library/svelte": "^5.2.1",
		"@types/eslint": "8.56.0",
		"@typescript-eslint/eslint-plugin": "^6.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.35.1",
		"jsdom": "^25.0.1",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"publint": "^0.1.9",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^2.1.8"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module"
}
